# lombok.config — ClaudeHut Spring Boot 3.x recommended baseline.
# Drop at project root. For mono-repos, also drop a `config.stopBubbling=true`
# at each module root so a parent never overrides a module's policy by accident.

# Anchor: do not inherit from any parent directory.
config.stopBubbling = true

# Tag generated code; JaCoCo / SonarQube respect @lombok.Generated.
lombok.addLombokGeneratedAnnotation = true

# @NonNull throws NullPointerException with the field name.
lombok.nonNull.exceptionType = NullPointerException

# Force a decision on inheritance.
lombok.equalsAndHashCode.callSuper = WARN
lombok.toString.callSuper        = SKIP

# Surface experimental annotations during code review.
lombok.experimental.flagUsage = WARNING

# Keep modifiers explicit — reviewers want to read them.
lombok.fieldDefaults.defaultPrivate = false
lombok.fieldDefaults.defaultFinal   = false

# Disable Lombok-only var/val (Java has these natively).
lombok.var.flagUsage = ERROR
lombok.val.flagUsage = WARNING

# Flag the foot-gun annotations explicitly so they show up in reviews.
lombok.data.flagUsage              = WARNING
lombok.allArgsConstructor.flagUsage = WARNING

# Disable fluent accessors (break Jackson default deserialization).
lombok.accessors.chain  = false
lombok.accessors.fluent = false

# Propagate Jackson + Jakarta Validation annotations to generated builders.
lombok.copyableAnnotations += com.fasterxml.jackson.annotation.JsonProperty
lombok.copyableAnnotations += com.fasterxml.jackson.annotation.JsonAlias
lombok.copyableAnnotations += com.fasterxml.jackson.annotation.JsonIgnore
lombok.copyableAnnotations += jakarta.validation.constraints.NotNull
lombok.copyableAnnotations += jakarta.validation.constraints.NotBlank
lombok.copyableAnnotations += jakarta.validation.constraints.NotEmpty
lombok.copyableAnnotations += jakarta.validation.constraints.Size
lombok.copyableAnnotations += jakarta.validation.constraints.Email
lombok.copyableAnnotations += jakarta.validation.constraints.Pattern
lombok.copyableAnnotations += jakarta.validation.constraints.Positive
lombok.copyableAnnotations += jakarta.validation.constraints.PositiveOrZero
lombok.copyableAnnotations += jakarta.validation.constraints.Min
lombok.copyableAnnotations += jakarta.validation.constraints.Max
