{
  "$schema": "https://raw.githubusercontent.com/taipt1504/claudehut/main/schema/config.schema.json",
  "version": "0.1.0",
  "phase": {
    "loop_max_retries": 3,
    "allow_skip_phases": [],
    "destructive_command_allowlist": []
  },
  "reuse_detection": {
    "stale_threshold_minutes": 10,
    "prefer_backends": ["understand_anything", "graphify"],
    "fallback_to_grep": true
  },
  "memory": {
    "promotion_min_projects": 3,
    "decay_days": 180,
    "global_promotion_opt_in": false
  },
  "coverage": {
    "line_threshold": 0.80,
    "branch_threshold": 0.70
  },
  "rules_override": {},
  "mcp_servers_enabled": ["context7", "memory", "sequential-thinking"],
  "agents": {
    "builder_model": "claude-sonnet-4-6",
    "reviewer_models": {
      "default": "claude-sonnet-4-6",
      "style": "claude-haiku-4-5",
      "mapping": "claude-haiku-4-5"
    }
  }
}
