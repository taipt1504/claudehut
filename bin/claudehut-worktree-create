#!/usr/bin/env bash
# create-worktree.sh — create git worktree for a feature branch
set -euo pipefail

BRANCH="${1:-}"
[[ -z "$BRANCH" ]] && { echo "usage: create-worktree.sh <branch>" >&2; exit 2; }

PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$(pwd)}"
cd "$PROJECT_ROOT"

git rev-parse --git-dir >/dev/null 2>&1 || { echo "error: not a git repo" >&2; exit 1; }

case "$BRANCH" in
  main|master|trunk|develop|dev) echo "error: cannot create worktree on default branch '$BRANCH'" >&2; exit 1 ;;
esac

# Derive task_id
TASK_ID="$(printf '%s' "$BRANCH" | tr '/' '-' | tr -c '[:alnum:]-' '-')"
WT_PATH="$PROJECT_ROOT/.worktrees/$TASK_ID"

if [[ -d "$WT_PATH" ]]; then
  echo "error: worktree already exists at $WT_PATH" >&2
  exit 1
fi

# Create worktree (branch may exist or be created)
if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
  git worktree add "$WT_PATH" "$BRANCH"
else
  git worktree add -b "$BRANCH" "$WT_PATH"
fi

echo "Worktree ready: $WT_PATH"
echo "Branch:        $BRANCH"
echo "Task ID:       $TASK_ID"
echo ""
echo "Next: cd $WT_PATH && claude --plugin-dir $CLAUDE_PLUGIN_ROOT"
