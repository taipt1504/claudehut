#!/usr/bin/env bash
# archive-task.sh — finalize and archive a completed task
set -euo pipefail

PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$(pwd)}"
cd "$PROJECT_ROOT"

_find_plugin_root() {
  if [[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]]; then echo "$CLAUDE_PLUGIN_ROOT"; return; fi
  local d
  d="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd -P)"
  while [[ "$d" != "/" && -n "$d" ]]; do
    [[ -f "$d/.claude-plugin/plugin.json" ]] && { echo "$d"; return; }
    d="$(dirname "$d")"
  done
  echo "error: cannot locate ClaudeHut plugin root" >&2; exit 1
}
PLUGIN_ROOT="$(_find_plugin_root)"
# shellcheck source=../hooks/lib/state.sh
source "$PLUGIN_ROOT/hooks/lib/state.sh"

TASK_ID="$(claudehut_active_task)"
[[ "$TASK_ID" == "none" ]] && { echo "error: no active task" >&2; exit 1; }

# --abandon (4.4): give up on a task that did NOT pass. Bypasses the {done,learn}
# gate and records the terminal usefulness signal (the retrieved learnings get
# used++ without useful++ when findings.decision=fail) — the fail-path callsite.
ABANDON=""
[[ "${1:-}" == "--abandon" ]] && ABANDON=1

PHASE="$(claudehut_phase "$TASK_ID")"
if [[ -z "$ABANDON" && "$PHASE" != "done" && "$PHASE" != "learn" ]]; then
  echo "error: task '$TASK_ID' is in phase '$PHASE' — finish Learn phase first (or 'claudehut-finish --abandon' to give up and record the outcome)" >&2
  exit 1
fi

# Refuse if uncommitted
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "error: uncommitted changes — commit before finishing" >&2
  exit 1
fi

if [[ -n "$ABANDON" ]]; then
  echo "Will ABANDON task: $TASK_ID (phase=$PHASE) — records the outcome signal, archives, clears pointer."
else
  echo "Will finish task: $TASK_ID"
fi
read -r -p "Confirm? [yes/NO] " ans
[[ "$ans" == "yes" ]] || { echo "Aborted."; exit 0; }

# Phase 4.3/4.4 — capture the TERMINAL usefulness signal for the learnings that
# were JIT-retrieved into this task, BEFORE the retrieval log is pruned below.
# On a passed task the learner already ran this (idempotent marker → no-op). On an
# abandoned/failed task THIS is the only callsite, so the fail outcome
# (findings.decision=fail → used++ without useful++) is recorded here. Best-effort.
if [[ -x "$PLUGIN_ROOT/skills/learn/scripts/update-usefulness.sh" ]]; then
  CLAUDE_PROJECT_DIR="$PROJECT_ROOT" bash "$PLUGIN_ROOT/skills/learn/scripts/update-usefulness.sh" "$TASK_ID" || true
fi

TS="$(date -u +%Y%m%dT%H%M%SZ)"
SRC="$(claudehut_state_dir)/tasks/$TASK_ID"
DST="$(claudehut_state_dir)/tasks/_archive/${TASK_ID}-${TS}"

# Archive the mutable state dir IF it exists. The artifact-derived design keeps
# task artifacts in specs/plans/findings/memory (not state/tasks), so SRC may be
# absent — finishing must still succeed and clean up the pointer/lock.
if [[ -d "$SRC" ]]; then
  mkdir -p "$(dirname "$DST")"
  mv "$SRC" "$DST"
  echo "Task state archived: $TASK_ID → _archive/$(basename "$DST")"
fi

# Release lock + clear the active-task pointer (written by SessionStart, 1.7).
rm -f "$(claudehut_state_dir)/lockfile.d/$TASK_ID"
rm -f "$(claudehut_state_dir)/active-task.json"

# Prune the per-task retrieval log + scored-marker (ephemeral state; their signal
# was consumed by update-usefulness above). Keeps .claudehut/state/ from
# accumulating one file per task forever (the deferred-pruning item).
rm -f "$(claudehut_state_dir)/retrieval-${TASK_ID}.json"
rm -f "$(claudehut_state_dir)/usefulness-scored-${TASK_ID}.marker"

echo "Task finished: $TASK_ID"
echo ""
echo "Next steps:"
echo "  - Push:    git push -u origin $(git symbolic-ref --short HEAD)"
echo "  - Or PR:   gh pr create"
echo "  - Or switch to a new task with /claudehut:start <slug>"
