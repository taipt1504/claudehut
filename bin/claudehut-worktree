#!/usr/bin/env bash
# claudehut-worktree — deterministic lifecycle for the plugin's MANAGED agent worktrees.
# Managed root: ${CLAUDE_PROJECT_DIR:-$PWD}/.claude/worktrees  (where native `isolation: worktree` creates them).
# HARD SCOPE GUARD: every mutating operation validates its target is under the managed root —
# this tool can NEVER touch user worktrees elsewhere, and never runs a bare destructive prune first.
#
# Usage:
#   claudehut-worktree status                          # list managed worktrees: branch, dirty?, merged?
#   claudehut-worktree check-disjoint <plan.md>        # [P] rows of the T-xxx table: exit 0 if Files are pairwise
#                                                      #   disjoint; exit 2 + the overlapping paths if not.
#   claudehut-worktree reconcile <branch> [--test-cmd CMD]
#                                                      # serialized merge of ONE agent branch into the current
#                                                      #   branch: refuses on dirty tree; --no-ff merge; on conflict
#                                                      #   aborts cleanly (exit 2); if CMD given, runs it and on
#                                                      #   failure resets the merge (exit 3). One branch per call —
#                                                      #   merge, test, then call again for the next (25-32% of
#                                                      #   parallel AI branches conflict; never batch-merge).
#   claudehut-worktree sweep                           # remove ONLY worktrees that are clean AND merged/unchanged
#                                                      #   (+ delete their branch), then prune stale metadata.
set -uo pipefail
err() { echo "claudehut-worktree: $*" >&2; exit 1; }
PROJ="${CLAUDE_PROJECT_DIR:-$PWD}"
cd "$PROJ" 2>/dev/null || err "cannot cd to project dir $PROJ"
git rev-parse --git-dir >/dev/null 2>&1 || err "not a git repository: $PROJ"
MROOT="$(cd "$PROJ" && pwd -P)/.claude/worktrees"

# scope guard: realpath of target must be strictly under MROOT
managed() { # $1 path -> 0 if under managed root
  local p; p="$(cd "$1" 2>/dev/null && pwd -P)" || return 1
  case "$p/" in "$MROOT"/*) return 0 ;; *) return 1 ;; esac
}

# managed worktree paths (from git's own registry, filtered to MROOT)
managed_list() {
  git worktree list --porcelain | awk '/^worktree /{print $2}' | while read -r w; do
    case "$(cd "$w" 2>/dev/null && pwd -P)/" in "$MROOT"/*) echo "$w" ;; esac
  done
}

wt_branch() { git -C "$1" rev-parse --abbrev-ref HEAD 2>/dev/null; }
wt_dirty()  { [ -n "$(git -C "$1" status --porcelain 2>/dev/null)" ]; }
wt_merged() { # branch tip reachable from main HEAD, or never advanced past merge-base
  local b="$1" tip base
  tip="$(git rev-parse "$b" 2>/dev/null)" || return 1
  git merge-base --is-ancestor "$tip" HEAD 2>/dev/null
}

sub="${1:-}"; shift || true
case "$sub" in
  status)
    found=false
    while read -r w; do
      [ -n "$w" ] || continue; found=true
      b="$(wt_branch "$w")"; d="clean"; wt_dirty "$w" && d="DIRTY"
      m="unmerged"; wt_merged "$b" && m="merged"
      echo "$w  branch=$b  $d  $m"
    done <<<"$(managed_list)"
    $found || echo "(no managed worktrees under .claude/worktrees/)"
    ;;

  check-disjoint)
    plan="${1:-}"; [ -f "$plan" ] || err "check-disjoint needs <plan.md>"
    # rows of the T-xxx table whose ID cell carries [P]; Files = 3rd cell
    overlaps="$(awk -F'|' '
      /^\|[[:space:]]*T-[0-9]+/ && $2 ~ /\[P\]/ {
        n=split($4, f, /[,[:space:]]+/)
        for (i=1;i<=n;i++) if (f[i] ~ /\//) print f[i]
      }' "$plan" | sort | uniq -d)"
    if [ -n "$overlaps" ]; then
      echo "OVERLAP — these paths appear in more than one [P] task (parallel dispatch is UNSAFE; run them sequentially):"
      echo "$overlaps"
      exit 2
    fi
    echo "disjoint: all [P] task Files are pairwise distinct — parallel dispatch is safe."
    ;;

  reconcile)
    b="${1:-}"; [ -n "$b" ] || err "reconcile needs <branch>"; shift || true
    tcmd=""; [ "${1:-}" = "--test-cmd" ] && tcmd="${2:-}"
    git rev-parse --verify "$b" >/dev/null 2>&1 || err "no such branch: $b"
    # tracked modifications only — the managed worktree dirs themselves are untracked under .claude/,
    # and git merge already refuses to clobber untracked files.
    [ -z "$(git status --porcelain --untracked-files=no)" ] || err "main tree has uncommitted tracked changes — commit or stash before reconciling"
    if ! git merge --no-ff "$b" -m "claudehut: reconcile agent branch $b" >/dev/null 2>&1; then
      git merge --abort >/dev/null 2>&1 || true
      echo "CONFLICT merging $b — merge aborted, tree restored. Resolve manually or re-plan the task." >&2
      exit 2
    fi
    if [ -n "$tcmd" ]; then
      if ! bash -c "$tcmd"; then
        git reset --hard ORIG_HEAD >/dev/null 2>&1
        echo "TESTS RED after merging $b — merge rolled back (ORIG_HEAD). Fix in the agent branch, then reconcile again." >&2
        exit 3
      fi
    fi
    echo "reconciled: $b merged$( [ -n "$tcmd" ] && echo " (tests green)" )."
    ;;

  sweep)
    removed=0; kept=0
    while read -r w; do
      [ -n "$w" ] || continue
      managed "$w" || { echo "skip (outside managed root — guard): $w"; kept=$((kept+1)); continue; }
      b="$(wt_branch "$w")"
      if wt_dirty "$w"; then echo "keep (DIRTY — uncommitted agent work, reconcile or inspect first): $w"; kept=$((kept+1)); continue; fi
      if ! wt_merged "$b"; then echo "keep (branch $b not merged — reconcile first): $w"; kept=$((kept+1)); continue; fi
      git worktree remove "$w" >/dev/null 2>&1 || { echo "keep (git refused remove): $w"; kept=$((kept+1)); continue; }
      [ -n "$b" ] && [ "$b" != "HEAD" ] && git branch -d "$b" >/dev/null 2>&1 || true
      echo "removed: $w (branch $b)"; removed=$((removed+1))
    done <<<"$(managed_list)"
    git worktree prune >/dev/null 2>&1 || true   # metadata only — runs AFTER scoped removals
    echo "sweep: removed=$removed kept=$kept (kept = dirty or unmerged; nothing outside .claude/worktrees/ touched)"
    ;;

  *) err "unknown subcommand: ${sub:-<none>} (status|check-disjoint|reconcile|sweep)" ;;
esac
